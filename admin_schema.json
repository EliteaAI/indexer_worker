{
  "$schema": "https://elitea.ai/admin-config-schema/v1",
  "plugin": "indexer_worker",
  "properties": {
    "sdk_dev_reload": {
      "type": "boolean",
      "title": "SDK Hot Reload",
      "description": "When enabled, the SDK is reloaded from disk on every agent run instead of using cached modules. Useful during SDK development to pick up code changes instantly without restarting the service. Keep disabled in production for better performance.",
      "path": "sdk_dev_reload",
      "section": "runtime",
      "default": false,
      "requires_restart": false
    },
    "mcp_servers": {
      "type": "object",
      "title": "MCP Server Definitions",
      "description": "Pre-configured MCP servers that appear as selectable toolkits. Supports stdio (local subprocess) and http (remote) server types.",
      "path": "mcp_servers",
      "section": "mcp_servers",
      "default": {},
      "requires_restart": false,
      "value_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "object",
        "propertyNames": {
          "type": "string",
          "minLength": 1
        },
        "additionalProperties": {
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "http",
                "stdio"
              ]
            },
            "url": {
              "type": "string",
              "pattern": "^https?://"
            },
            "command": {
              "type": "string",
              "minLength": 1
            },
            "args": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "runtime": {
              "type": "string",
              "enum": [
                "npm",
                "python"
              ]
            },
            "package": {
              "type": "string",
              "minLength": 1
            },
            "description": {
              "type": "string"
            },
            "display_name": {
              "type": "string"
            },
            "icon_url": {
              "type": "string"
            },
            "headers": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "env": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "env_mapping": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "timeout": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "ssl_verify": {
              "type": "boolean"
            },
            "stateful": {
              "type": "boolean"
            },
            "config_schema": {
              "type": "object"
            },
            "tools": {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            "selected_tools": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "excluded_tools": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "type": {
                    "const": "http"
                  }
                }
              },
              "then": {
                "required": [
                  "url"
                ]
              }
            },
            {
              "if": {
                "properties": {
                  "type": {
                    "const": "stdio"
                  }
                }
              },
              "then": {
                "required": [
                  "command"
                ]
              }
            }
          ],
          "additionalProperties": true
        }
      }
    }
  }
}
